# ── FitGrowX WA Server — Variables de Entorno ────────────────────────────────

# Puerto en el que escucha el servidor (default: 3000)
PORT=3000

# API key para proteger los endpoints del servidor
# Debe coincidir con WA_MOTOR_API_KEY en el .env.local de la App
API_KEY=cambia_esto_por_un_api_key_seguro

# URL pública de tu App Next.js (sin trailing slash)
# Ej: https://app.fitgrowx.com  ó  https://TU_DOMINIO_VERCEL.app
NEXT_APP_URL=https://TU_APP.vercel.app

# ID del gym que está usando este servidor
# Debe coincidir con el gym_id en Supabase
GYM_ID=uuid-del-gym-en-supabase

# Secret compartido para validar los webhooks
# Debe coincidir con WA_WEBHOOK_SECRET en el .env.local de la App
WEBHOOK_SECRET=cambia_esto_por_un_secreto_largo

# Carpeta donde se guarda la sesión de WA (relativa al server.js)
AUTH_DIR=./auth_state
